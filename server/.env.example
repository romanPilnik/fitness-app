# Copy to .env and fill in. See README / AGENTS.md.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fitness_app"

PORT=5001
NODE_ENV=development

BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:5001"
CLIENT_ORIGIN="http://localhost:5173"

# Optional: require verified email before email/password sign-in (needs Resend or AUTH_EMAIL_MODE=console)
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# Auth emails: "console" logs links to stdout; use Resend in production
# AUTH_EMAIL_MODE=console
# RESEND_API_KEY=
# RESEND_FROM=onboarding@resend.dev

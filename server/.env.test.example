# Copy to `.env.test` in this directory (gitignored). Run commands from `server/`
# so `src/test/setup.ts` resolves `.env.test` via `process.cwd()`.
#
# Use the Docker Compose `db_test` service (host port 5433 by default).
# 1. docker compose up -d db_test   (or npm run db:test:up)
# 2. npm run db:test:migrate
# 3. npm run test:integration

NODE_ENV=test
PORT=5001

DATABASE_URL="postgresql://admin:myPassword@localhost:5433/fitness_app_test"

# Auth — test-only secret; required for JWT integration tests
JWT_SECRET=your_test_secret_key_min_32_characters_long
JWT_EXPIRE=7d
